# Caedral SDK — test environment
# Copy to .env and fill in values to run integration tests.

# Required for tests
CAEDRAL_API_KEY=cd_live_your_key_here
CAEDRAL_BASE_URL=http://localhost:5001

# Required for integration tests that create test keys
DATABASE_URL=postgresql://caedral:password@localhost:5432/caedral

# Optional (for live model tests)
OPENROUTER_API_KEY=sk-or-v1-...
