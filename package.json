{
  "name": "caedral",
  "version": "0.1.0",
  "description": "Official TypeScript/JavaScript client for the Caedral API — OpenAI-compatible chat completions, embeddings, images, audio, and rerank",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "caedral",
    "ai",
    "llm",
    "api",
    "openai",
    "chat-completions",
    "embeddings",
    "typescript",
    "javascript",
    "sdk",
    "machine-learning"
  ],
  "author": {
    "name": "Caedral",
    "email": "hello@caedral.com",
    "url": "https://caedral.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caedral/caedral.git"
  },
  "homepage": "https://caedral.com/docs/typescript",
  "bugs": {
    "url": "https://github.com/caedral/caedral/issues"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.7",
    "postgres": "^3.4.9",
    "tsup": "^8.4.0",
    "typescript": "^5",
    "vitest": "^3.0.9"
  }
}
